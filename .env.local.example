# ─────────────────────────────────────────────────────────────
# push.bat से Supabase database-structure अपने-आप update कराने के लिए:
#  1. इस फ़ाइल की copy बनाकर नाम रखें:  .env.local
#  2. नीचे की दोनों values भरें
# (.env.local git/GitHub पर कभी नहीं जाती — secrets सुरक्षित रहते हैं)
#
# SUPABASE_ACCESS_TOKEN कहाँ से मिलेगा:
#   https://supabase.com/dashboard/account/tokens
#   → "Generate new token" → नाम दें (जैसे push-script) → token copy करें (sbp_ से शुरू)
#
# SUPABASE_PROJECT_REF कहाँ से मिलेगा:
#   Supabase dashboard खोलने पर URL में:
#   https://supabase.com/dashboard/project/<यही-16-अक्षर-वाला-ref>
#   (या Project Settings → General → Reference ID)
# ─────────────────────────────────────────────────────────────

SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_PROJECT_REF=xxxxxxxxxxxxxxxx
